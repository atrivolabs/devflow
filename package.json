{
  "name": "devflow",
  "version": "0.1.0",
  "description": "CLI focus companion for developers — music, pomodoro, and session flow",
  "type": "module",
  "bin": {
    "devflow": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "pomodoro",
    "focus",
    "music",
    "lofi",
    "developer",
    "productivity",
    "terminal",
    "coding",
    "timer"
  ],
  "author": "Atrivo Labs",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^18.3.18",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
